generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id         Int        @id @default(autoincrement())
  source     String
  externalId String
  title      String
  url        String?
  createdAt  DateTime?
  fetchedAt  DateTime   @default(now())
  topicHits  TopicHit[]

  @@unique([source, externalId])
}

model TopicHit {
  id                   Int      @id @default(autoincrement())
  bucketTime           DateTime
  category             String
  parentKey            String
  parentLabel          String
  canonicalParentKey   String?
  canonicalParentLabel String?
  childKey             String?
  childLabel           String?
  postId               Int
  createdAt            DateTime @default(now())
  post                 Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([bucketTime, postId])
  @@index([bucketTime, category, parentKey])
  @@index([bucketTime, canonicalParentKey])
}
