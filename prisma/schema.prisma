generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id         Int      @id @default(autoincrement())
  source     String
  externalId String
  title      String
  createdAt  DateTime?
  fetchedAt  DateTime @default(now())
  evidences  TopicEvidence[]

  @@unique([source, externalId])
}

model TopicCount {
  id         Int      @id @default(autoincrement())
  topic      String
  topicLabel String   @default("")
  bucketTime DateTime
  count      Int

  @@unique([topic, bucketTime])
}

model TopicEvidence {
  id         Int      @id @default(autoincrement())
  topic      String
  bucketTime DateTime
  postId     Int
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([topic, bucketTime, postId])
  @@index([topic, bucketTime])
}
